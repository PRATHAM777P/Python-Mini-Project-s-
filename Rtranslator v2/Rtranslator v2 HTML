<div id="toast"></div>

<script>
// ════════════════════════════════════════════
// SECURITY: Input sanitization — always escape user-generated content
// before inserting into DOM. Never use innerHTML with unsanitized data.
// ════════════════════════════════════════════
const $ = id => document.getElementById(id);
const esc = s => String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');

// ── State (no secrets in global state) ──────
const ST = {
  tab: 'text',
  demoMode: true,
  micActive: false,
  recognition: null,
  history: [],
  prefs: { autoSpeak: false, mic: true, history: true },
  curTranslation: '',
  curInput: '',
  walkieBusy: false,
};

// ── LANG MAP ────────────────────────────────
const LANG_BCP47 = {
  English:'en-US', Spanish:'es-ES', French:'fr-FR', German:'de-DE',
  Italian:'it-IT', Portuguese:'pt-PT', Chinese:'zh-CN', Japanese:'ja-JP',
  Korean:'ko-KR', Arabic:'ar-SA', Russian:'ru-RU', Hindi:'hi-IN',
  Turkish:'tr-TR', Dutch:'nl-NL', Polish:'pl-PL', Ukrainian:'uk-UA',
};
const FLAGS = {
  English:'🇬🇧', Spanish:'🇪🇸', French:'🇫🇷', German:'🇩🇪', Italian:'🇮🇹',
  Portuguese:'🇵🇹', Chinese:'🇨🇳', Japanese:'🇯🇵', Korean:'🇰🇷', Arabic:'🇸🇦',
  Russian:'🇷🇺', Hindi:'🇮🇳', Turkish:'🇹🇷', Dutch:'🇳🇱', Polish:'🇵🇱', Ukrainian:'🇺🇦',
};

// ── BOOT ────────────────────────────────────
window.addEventListener('DOMContentLoaded', () => {
  loadPrefs();
  loadHistory();
  updateClock();
  setInterval(updateClock, 15000);

  setTimeout(() => {
    $('splash').classList.add('out');
    // Check for API key SECURELY — never log it
    const hasKey = !!secureGetKey();
    ST.demoMode = !hasKey;
    if (!hasKey) showKeySheet();
    updateKeyStatus();
  }, 1900);
});

function updateClock() {
  const n = new Date();
  $('mode-time').textContent = n.getHours().toString().padStart(2,'0') + ':' + n.getMinutes().toString().padStart(2,'0');
}

// ── SECURE KEY STORAGE ──────────────────────
// SECURITY: Key is stored in localStorage with a namespaced key.
// It is only ever sent to api.anthropic.com — validated before use.
// Never log, display fully, or expose in URLs.
const KEY_STORE = 'rt2_key_v1';

function secureGetKey() {
  try { return localStorage.getItem(KEY_STORE) || ''; } catch { return ''; }
}

function secureSaveKey(k) {
  // Validate format before saving — prevents XSS via injected keys
  if (!/^sk-ant-[a-zA-Z0-9\-_]{10,}$/.test(k)) return false;
  try { localStorage.setItem(KEY_STORE, k); return true; } catch { return false; }
}

function secureClearKey() {
  try { localStorage.removeItem(KEY_STORE); } catch {}
}

function saveKey() {
  const raw = $('key-input').value.trim();
  if (!raw) { toast('Please enter your API key', 'err'); return; }
  if (!raw.startsWith('sk-ant-')) { toast('Key must start with sk-ant-', 'err'); return; }
  if (raw.length < 30) { toast('Key looks too short', 'err'); return; }
  if (!secureSaveKey(raw)) { toast('Invalid key format', 'err'); return; }
  $('key-input').value = ''; // SECURITY: Clear from DOM immediately
  ST.demoMode = false;
  $('key-sheet').classList.add('hidden');
  updateKeyStatus();
  toast('API key saved — AI translation active!', 'ok');
}

function useDemoMode() {
  ST.demoMode = true;
  $('key-sheet').classList.add('hidden');
  toast('Demo mode active — simulated translations');
}

function showKeySheet() { $('key-sheet').classList.remove('hidden'); }
function updateKeyStatus() {
  const k = secureGetKey();
  if (k) {
    // SECURITY: Never show full key — mask everything except last 4 chars
    $('key-status-desc').textContent = 'Configured · sk-ant-•••' + k.slice(-4);
  } else {
    $('key-status-desc').textContent = 'Not configured · Demo mode active';
  }
}

// ── TAB NAVIGATION ──────────────────────────
function switchTab(tab) {
  ST.tab = tab;
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  $('tab-' + tab).classList.add('active');
  $('screen-' + tab).classList.add('active');
  const labels = { text:'TEXT MODE', conv:'CONVO MODE', walkie:'WALKIE MODE', hist:'HISTORY' };
  $('mode-label').textContent = labels[tab] || tab.toUpperCase();
}

function openSettings() {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  $('screen-settings').classList.add('active');
  $('mode-label').textContent = 'SETTINGS';
}

function closeSettings() { switchTab(ST.tab); }

// ── LANG CONTROLS ──────────────────────────
function swapLangs(mode) {
  if (mode === 't') {
    const f = $('t-from'), t = $('t-to');
    [f.value, t.value] = [t.value, f.value];
    updateTextLabels();
    // Also swap text content
    const inp = $('t-input').value;
    const out = $('t-output').textContent;
    const isEmpty = $('t-output').classList.contains('empty');
    if (!isEmpty && out && out !== 'Translation will appear here…') {
      $('t-input').value = out;
      $('t-output').textContent = inp || 'Translation will appear here…';
      if (!inp) $('t-output').classList.add('empty');
      updateCharCnt();
    }
  } else if (mode === 'w') {
    const l = $('w-left'), r = $('w-right');
    [l.value, r.value] = [r.value, l.value];
    updateWalkieLangs();
  }
}

function updateTextLabels() {
  $('t-from-label').textContent = 'SOURCE · ' + $('t-from').value.toUpperCase();
  $('t-to-label').textContent = 'TRANSLATION · ' + $('t-to').value.toUpperCase();
}

function updateWalkieLangs() {
  $('w-lang-left').textContent = $('w-left').value;
  $('w-lang-right').textContent = $('w-right').value;
}

// ── TEXT INPUT ──────────────────────────────
function onInput() { updateCharCnt(); }
function updateCharCnt() { $('char-cnt').textContent = $('t-input').value.length; }
function clearText() {
  $('t-input').value = ''; updateCharCnt();
  setOutputEmpty(); setStatus('Ready'); stopMic();
}
function setOutputEmpty() {
  $('t-output').textContent = 'Translation will appear here…';
  $('t-output').className = 'tcard-output empty';
  ST.curTranslation = '';
}

// ── TRANSLATE ────────────────────────────────
async function doTranslate() {
  const text = $('t-input').value.trim();
  if (!text) { toast('Enter some text to translate'); return; }
  const from = $('t-from').value, to = $('t-to').value;
  if (from === to) { toast('Source and target must differ'); return; }

  const btn = $('cta-btn');
  btn.disabled = true;
  btn.innerHTML = '<div class="spinner" style="border-color:rgba(0,0,0,.2);border-top-color:#000;width:18px;height:18px;"></div> Translating…';
  setStatus('', true);

  try {
    const result = await translateText(text, from, to);
    ST.curTranslation = result;
    ST.curInput = text;
    const out = $('t-output');
    out.textContent = result;
    out.className = 'tcard-output';
    setStatus('Done ✓');
    if (ST.prefs.autoSpeak) speak(result, to);
    if (ST.prefs.history) addToHistory(text, result, from, to);
  } catch(e) {
    setStatus('Error: ' + e.message);
    toast(e.message, 'err');
  }

  btn.disabled = false;
  btn.innerHTML = '<svg viewBox="0 0 24 24" style="width:18px;height:18px;fill:none;stroke:#000;stroke-width:2.2;stroke-linecap:round;stroke-linejoin:round"><path d="M5 8l6 6"/><path d="M4 14l6-6 2-3"/><path d="M2 5h12"/><path d="M7 2h1"/><path d="M22 22l-5-10-5 10"/><path d="M14 18h6"/></svg>Translate';
}

async function translateText(text, from, to) {
  // SECURITY: Sanitize input before sending to API
  const safeText = text.slice(0, 1000); // Enforce max length
  if (ST.demoMode) return demoTranslate(safeText, from, to);
  const key = secureGetKey();
  if (!key) throw new Error('No API key. Tap 🔑 to add one.');

  const resp = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'x-api-key': key,
      'anthropic-version': '2023-06-01',
      'anthropic-dangerous-direct-browser-access': 'true',
    },
    body: JSON.stringify({
      model: 'claude-sonnet-4-20250514',
      max_tokens: 1000,
      // SECURITY: System prompt injection prevention — use structured messages
      system: 'You are a professional translator. Translate the provided text accurately and naturally. Output ONLY the translation — no notes, no explanations, no prefixes.',
      messages: [{ role: 'user', content: `Translate from ${esc(from)} to ${esc(to)}:\n\n${safeText}` }],
    }),
  });

  if (!resp.ok) {
    const err = await resp.json().catch(() => ({}));
    // SECURITY: Don't expose raw API errors to UI — sanitize message
    const msg = err?.error?.message || 'API request failed';
    if (resp.status === 401) throw new Error('Invalid API key');
    if (resp.status === 429) throw new Error('Rate limit reached. Try again shortly.');
    throw new Error(msg.slice(0, 100));
  }

  const data = await resp.json();
  return data.content?.[0]?.text?.trim() || 'Translation unavailable';
}

function demoTranslate(text, from, to) {
  const demos = {
    Spanish: { 'Hello': 'Hola', 'Good morning': 'Buenos días', 'Thank you': 'Gracias', 'How are you?': '¿Cómo estás?', 'I love you': 'Te quiero', 'Where are you?': '¿Dónde estás?' },
    French:  { 'Hello': 'Bonjour', 'Thank you': 'Merci', 'Good morning': 'Bonjour', 'How are you?': 'Comment allez-vous?', 'I love you': "Je t'aime" },
    German:  { 'Hello': 'Hallo', 'Thank you': 'Danke', 'Good morning': 'Guten Morgen', 'How are you?': 'Wie geht es Ihnen?', 'I love you': 'Ich liebe dich' },
    Japanese:{ 'Hello': 'こんにちは', 'Thank you': 'ありがとう', 'Good morning': 'おはようございます', 'I love you': '愛してる' },
    Chinese: { 'Hello': '你好', 'Thank you': '谢谢', 'Good morning': '早上好', 'I love you': '我爱你' },
    Arabic:  { 'Hello': 'مرحبا', 'Thank you': 'شكرا', 'Good morning': 'صباح الخير', 'I love you': 'أحبك' },
    Russian: { 'Hello': 'Привет', 'Thank you': 'Спасибо', 'Good morning': 'Доброе утро', 'I love you': 'Я тебя люблю' },
    Hindi:   { 'Hello': 'नमस्ते', 'Thank you': 'धन्यवाद', 'Good morning': 'सुप्रभात', 'I love you': 'मैं तुमसे प्यार करता हूँ' },
  };
  return new Promise(res => setTimeout(() => {
    const map = demos[to] || {};
    const hit = map[text];
    res(hit || `[DEMO] "${text}" → ${to}. Add an API key for real AI translation.`);
  }, 700 + Math.random() * 500));
}

// ── STATUS LINE ─────────────────────────────
function setStatus(msg, loading) {
  const el = $('status-line');
  el.innerHTML = loading
    ? `<div class="spinner"></div><span style="font-size:12px;color:var(--text3)">${msg || 'Processing…'}</span>`
    : `<span id="status-txt" style="font-size:12px;color:var(--text3)">${esc(msg)}</span>`;
}

// ── TTS ─────────────────────────────────────
function speak(text, lang) {
  if (!window.speechSynthesis) { toast('TTS not supported'); return; }
  window.speechSynthesis.cancel();
  const u = new SpeechSynthesisUtterance(text);
  u.lang = LANG_BCP47[lang] || 'en-US';
  window.speechSynthesis.speak(u);
}
function speakInput()  { const t=$('t-input').value.trim(); if(t) speak(t,$('t-from').value); else toast('Nothing to speak'); }
function speakOutput() { if($('t-output').classList.contains('empty')) { toast('No translation yet'); return; } speak($('t-output').textContent,$('t-to').value); }

// ── MICROPHONE (STT) ─────────────────────────
function startMic() {
  if (!ST.prefs.mic) { toast('Mic disabled in Settings'); return; }
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SR) { toast('Speech recognition not supported (use Chrome)'); return; }
  if (ST.micActive) { stopMic(); return; }

  ST.recognition = new SR();
  ST.recognition.lang = LANG_BCP47[$('t-from').value] || 'en-US';
  ST.recognition.continuous = false;
  ST.recognition.interimResults = false;

  ST.micActive = true;
  $('mic-main-btn').classList.add('rec');
  $('mic-btn').classList.add('active');
  $('waveform').classList.add('active');
  $('mic-hint').textContent = 'Listening… tap to stop';
  setStatus('Listening…', true);

  ST.recognition.onresult = e => {
    const t = e.results[0][0].transcript;
    $('t-input').value = t;
    updateCharCnt();
    setStatus('Captured: "' + t.slice(0, 50) + (t.length > 50 ? '…' : '') + '"');
  };
  ST.recognition.onend = () => stopMic();
  ST.recognition.onerror = e => { stopMic(); setStatus('Mic error: ' + e.error); };
  ST.recognition.start();
}

function stopMic() {
  ST.micActive = false;
  ST.recognition?.abort();
  $('mic-main-btn').classList.remove('rec');
  $('mic-btn').classList.remove('active');
  $('waveform').classList.remove('active');
  $('mic-hint').textContent = 'Tap mic to speak';
}

// ── CONVERSATION MODE ────────────────────────
function convKey(e) { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); convSend(); } }

async function convSend() {
  const inp = $('c-input');
  const text = inp.value.trim();
  if (!text) return;
  const meLang = $('c-me').value, peerLang = $('c-peer').value;
  inp.value = '';
  addBubble('conv-chat', 'me', text, '');
  try {
    const tr = await translateText(text, meLang, peerLang);
    const last = $('conv-chat').lastElementChild;
    if (last) { const el = last.querySelector('.bubble-trans'); if (el) el.textContent = tr; }
    if (ST.prefs.autoSpeak) speak(tr, peerLang);
    if (ST.prefs.history) addToHistory(text, tr, meLang, peerLang);
  } catch(e) { toast(e.message, 'err'); }
}

async function convMic() {
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SR) { toast('Speech recognition not supported'); return; }
  const rec = new SR();
  rec.lang = LANG_BCP47[$('c-me').value] || 'en-US';
  const btn = $('c-mic-btn');
  btn.classList.add('rec');
  rec.onresult = e => { $('c-input').value = e.results[0][0].transcript; };
  rec.onend = () => btn.classList.remove('rec');
  rec.start();
}

// ── WALKIE-TALKIE MODE ───────────────────────
async function walkieTap(side) {
  if (ST.walkieBusy) return;
  ST.walkieBusy = true;
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SR) { ST.walkieBusy = false; toast('Speech recognition not supported'); return; }

  const isLeft = side === 'left';
  const speakLang = isLeft ? $('w-left').value : $('w-right').value;
  const listenLang = isLeft ? $('w-right').value : $('w-left').value;
  const pad = $('w-pad-' + side);
  pad.classList.add('talking');
  $('w-status').innerHTML = '<div class="spinner"></div><span style="font-size:13px;color:var(--glow)">Listening in ' + esc(speakLang) + '…</span>';

  const rec = new SR();
  rec.lang = LANG_BCP47[speakLang] || 'en-US';
  rec.onresult = async e => {
    const text = e.results[0][0].transcript;
    $('w-status').innerHTML = '<div class="spinner"></div><span style="font-size:13px;color:var(--text3)">Translating to ' + esc(listenLang) + '…</span>';
    addBubble('walkie-chat', isLeft ? 'peer' : 'me', text, '');
    try {
      const tr = await translateText(text, speakLang, listenLang);
      const last = $('walkie-chat').lastElementChild;
      if (last) { const el = last.querySelector('.bubble-trans'); if (el) el.textContent = tr; }
      $('w-status').innerHTML = '<span style="font-size:13px;color:var(--glow)">Speaking translation…</span>';
      speak(tr, listenLang);
      if (ST.prefs.history) addToHistory(text, tr, speakLang, listenLang);
      setTimeout(() => {
        pad.classList.remove('talking');
        $('w-status').innerHTML = '<span style="font-size:13px;color:var(--text3)">Tap a side to speak</span>';
        ST.walkieBusy = false;
      }, 2200);
    } catch(e) {
      $('w-status').innerHTML = '<span style="font-size:13px;color:var(--glowR)">Error: ' + esc(e.message) + '</span>';
      pad.classList.remove('talking');
      ST.walkieBusy = false;
    }
  };
  rec.onerror = () => {
    $('w-status').innerHTML = '<span style="font-size:13px;color:var(--glowR)">Mic error. Try again.</span>';
    pad.classList.remove('talking');
    ST.walkieBusy = false;
  };
  rec.onend = () => {
    if (ST.walkieBusy && !$('w-status').innerHTML.includes('Translating')) {
      pad.classList.remove('talking');
      $('w-status').innerHTML = '<span style="font-size:13px;color:var(--text3)">Tap a side to speak</span>';
      ST.walkieBusy = false;
    }
  };
  rec.start();
}

// ── CHAT BUBBLES ─────────────────────────────
function addBubble(chatId, who, original, translated) {
  const chat = $(chatId);
  const n = new Date();
  const time = n.getHours().toString().padStart(2,'0') + ':' + n.getMinutes().toString().padStart(2,'0');
  const div = document.createElement('div');
  div.className = 'bubble-wrap ' + who;
  // SECURITY: Always escape user-generated content
  div.innerHTML = `
    <div class="bubble">${esc(original)}</div>
    <div class="bubble-trans">${translated ? esc(translated) : 'Translating…'}</div>
    <div class="bubble-meta">${who === 'me' ? 'You' : 'Peer'} · ${time}</div>
  `;
  chat.appendChild(div);
  chat.scrollTop = chat.scrollHeight;
}

// ── HISTORY ──────────────────────────────────
function addToHistory(orig, trans, from, to) {
  const item = { orig, trans, from, to, t: Date.now() };
  ST.history.unshift(item);
  if (ST.history.length > 200) ST.history.pop();
  try { localStorage.setItem('rt2_history', JSON.stringify(ST.history)); } catch {}
  renderHistory();
}

function loadHistory() {
  try { ST.history = JSON.parse(localStorage.getItem('rt2_history') || '[]'); } catch { ST.history = []; }
  renderHistory();
}

function renderHistory() {
  const list = $('hist-list'), empty = $('hist-empty');
  list.innerHTML = '';
  if (!ST.history.length) { empty.style.display = 'block'; return; }
  empty.style.display = 'none';
  ST.history.slice(0, 50).forEach((item, i) => {
    const el = document.createElement('div');
    el.className = 'hist-item';
    const mins = Math.round((Date.now() - item.t) / 60000);
    const timeStr = mins < 1 ? 'now' : mins < 60 ? mins + 'm' : Math.round(mins/60) + 'h';
    // SECURITY: Always escape stored strings when rendering
    el.innerHTML = `
      <div class="hist-flag ${i%2===0?'a':'b'}">${FLAGS[item.from]||'🌐'}</div>
      <div class="hist-body">
        <div class="hist-orig">${esc(item.orig)}</div>
        <div class="hist-translated">${esc(item.trans)}</div>
        <div class="hist-langs">${esc(item.from)} → ${esc(item.to)}</div>
      </div>
      <div class="hist-time">${timeStr}</div>
    `;
    el.onclick = () => {
      $('t-input').value = item.orig; updateCharCnt();
      const out = $('t-output');
      out.textContent = item.trans; out.className = 'tcard-output';
      ST.curTranslation = item.trans; ST.curInput = item.orig;
      switchTab('text');
    };
    list.appendChild(el);
  });
}

function clearHistory() {
  if (!confirm('Delete all translation history?')) return;
  ST.history = [];
  try { localStorage.removeItem('rt2_history'); } catch {}
  renderHistory();
  toast('History cleared');
}

function saveItem() {
  if (!ST.curTranslation) { toast('No translation to save'); return; }
  addToHistory(ST.curInput, ST.curTranslation, $('t-from').value, $('t-to').value);
  toast('Saved to history', 'ok');
}

// ── SHARE ────────────────────────────────────
async function shareOut() {
  const out = $('t-output');
  if (out.classList.contains('empty')) { toast('No translation to share'); return; }
  const text = `[RTranslator]\n${$('t-from').value} → ${$('t-to').value}\n\n${$('t-input').value}\n↳ ${out.textContent}`;
  if (navigator.share) {
    try { await navigator.share({ title: 'RTranslator', text }); return; } catch {}
  }
  navigator.clipboard?.writeText(text).then(() => toast('Copied to clipboard', 'ok')).catch(() => toast('Share not supported'));
}

function copyOut() {
  const out = $('t-output');
  if (out.classList.contains('empty')) { toast('No translation to copy'); return; }
  navigator.clipboard?.writeText(out.textContent).then(() => toast('Copied!', 'ok')).catch(() => toast('Copy not supported'));
}

// ── PREFS ────────────────────────────────────
function loadPrefs() {
  try { ST.prefs = { ...ST.prefs, ...JSON.parse(localStorage.getItem('rt2_prefs') || '{}') }; } catch {}
  $('s-autospeak').checked = ST.prefs.autoSpeak;
  $('s-mic').checked = ST.prefs.mic;
  $('s-hist').checked = ST.prefs.history;
}
function savePref(k, v) {
  ST.prefs[k] = v;
  try { localStorage.setItem('rt2_prefs', JSON.stringify(ST.prefs)); } catch {}
}

// ── TOAST ────────────────────────────────────
let _toastTimer;
function toast(msg, type) {
  const el = $('toast');
  el.textContent = msg; // Safe: textContent, not innerHTML
  el.className = 'show' + (type ? ' ' + type : '');
  clearTimeout(_toastTimer);
  _toastTimer = setTimeout(() => el.className = '', 2800);
}
</script>
