</div>

<!-- ════ APP ════ -->
<div id="app">

  <!-- Top Bar -->
  <div id="topbar">
    <div class="brand">
      <div class="brand-icon">
        <svg viewBox="0 0 24 24"><path d="M5 8l6 6"/><path d="M4 14l6-6 2-3"/><path d="M2 5h12"/><path d="M7 2h1"/><path d="M22 22l-5-10-5 10"/><path d="M14 18h6"/></svg>
      </div>
      <div class="brand-name">R<em>Translator</em></div>
    </div>
    <div class="topbar-actions">
      <div class="icon-btn" onclick="openSettings()" title="Settings">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
      </div>
      <div class="icon-btn" onclick="showKeySheet()" title="API Key">
        <svg viewBox="0 0 24 24"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0 3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
      </div>
    </div>
  </div>

  <!-- Mode Pill -->
  <div id="mode-pill">
    <div class="mode-dot"></div>
    <div class="mode-label" id="mode-label">TEXT MODE</div>
    <div class="mode-time" id="mode-time">--:--</div>
  </div>

  <!-- Tabs -->
  <div id="tabs">
    <div class="tab active" id="tab-text" onclick="switchTab('text')">
      <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
      Text
    </div>
    <div class="tab" id="tab-conv" onclick="switchTab('conv')">
      <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      Convo
    </div>
    <div class="tab" id="tab-walkie" onclick="switchTab('walkie')">
      <svg viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="3"/><path d="M12 18h.01"/><path d="M9 7h6M9 11h6"/></svg>
      Walkie
    </div>
    <div class="tab" id="tab-hist" onclick="switchTab('hist')">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      History
    </div>
  </div>

  <!-- Main -->
  <div id="main">

    <!-- ══ TEXT SCREEN ══ -->
    <div class="screen active" id="screen-text">
      <!-- Lang selector -->
      <div class="lang-card">
        <select class="lang-pick" id="t-from"><option value="English">🇬🇧 English</option><option value="Spanish">🇪🇸 Spanish</option><option value="French">🇫🇷 French</option><option value="German">🇩🇪 German</option><option value="Italian">🇮🇹 Italian</option><option value="Portuguese">🇵🇹 Portuguese</option><option value="Chinese">🇨🇳 Chinese</option><option value="Japanese">🇯🇵 Japanese</option><option value="Korean">🇰🇷 Korean</option><option value="Arabic">🇸🇦 Arabic</option><option value="Russian">🇷🇺 Russian</option><option value="Hindi">🇮🇳 Hindi</option><option value="Turkish">🇹🇷 Turkish</option><option value="Dutch">🇳🇱 Dutch</option><option value="Polish">🇵🇱 Polish</option><option value="Ukrainian">🇺🇦 Ukrainian</option></select>
        <div class="swap-btn" onclick="swapLangs('t')"><svg viewBox="0 0 24 24"><path d="M7 16V4m0 0L3 8m4-4 4 4M17 8v12m0 0 4-4m-4 4-4-4"/></svg></div>
        <select class="lang-pick" id="t-to"><option value="Spanish">🇪🇸 Spanish</option><option value="English">🇬🇧 English</option><option value="French">🇫🇷 French</option><option value="German">🇩🇪 German</option><option value="Italian">🇮🇹 Italian</option><option value="Portuguese">🇵🇹 Portuguese</option><option value="Chinese">🇨🇳 Chinese</option><option value="Japanese">🇯🇵 Japanese</option><option value="Korean">🇰🇷 Korean</option><option value="Arabic">🇸🇦 Arabic</option><option value="Russian">🇷🇺 Russian</option><option value="Hindi">🇮🇳 Hindi</option><option value="Turkish">🇹🇷 Turkish</option><option value="Dutch">🇳🇱 Dutch</option><option value="Polish">🇵🇱 Polish</option><option value="Ukrainian">🇺🇦 Ukrainian</option></select>
      </div>

      <!-- Input card -->
      <div class="tcard">
        <div class="tcard-header">
          <div class="tcard-lang-label" id="t-from-label">SOURCE · ENGLISH</div>
          <div class="tcard-actions">
            <div class="tcard-btn" onclick="speakInput()" title="Speak input"><svg viewBox="0 0 24 24"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg></div>
            <div class="tcard-btn" id="mic-btn" onclick="startMic()" title="Microphone"><svg viewBox="0 0 24 24"><path d="M12 2a3 3 0 0 1 3 3v6a3 3 0 0 1-6 0V5a3 3 0 0 1 3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg></div>
            <div class="tcard-btn" onclick="clearText()" title="Clear"><svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></div>
          </div>
        </div>
        <div class="tcard-body">
          <textarea class="tcard-ta" id="t-input" placeholder="Type or use mic to enter text…" maxlength="1000" oninput="onInput()"></textarea>
          <div class="char-ring"><span id="char-cnt">0</span>/1000</div>
        </div>
      </div>

      <!-- Mic row -->
      <div style="background:var(--bg2);border:0.5px solid var(--border);border-radius:var(--r-lg);padding:12px 16px;">
        <div class="mic-wrap">
          <button class="mic-main" id="mic-main-btn" onclick="startMic()">
            <svg viewBox="0 0 24 24"><path d="M12 2a3 3 0 0 1 3 3v6a3 3 0 0 1-6 0V5a3 3 0 0 1 3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
          </button>
          <div class="waveform" id="waveform">
            <div class="wbar"></div><div class="wbar"></div><div class="wbar"></div>
            <div class="wbar"></div><div class="wbar"></div><div class="wbar"></div>
            <div class="wbar"></div>
          </div>
          <span class="mic-hint-text" id="mic-hint">Tap mic to speak</span>
        </div>
      </div>

      <!-- Status -->
      <div class="status-line" id="status-line"><span id="status-txt" style="font-size:12px;color:var(--text3)">Ready to translate</span></div>

      <!-- Output card -->
      <div class="tcard">
        <div class="tcard-header">
          <div class="tcard-lang-label" id="t-to-label">TRANSLATION · SPANISH</div>
          <div class="tcard-actions">
            <div class="tcard-btn" onclick="speakOutput()" title="Speak translation"><svg viewBox="0 0 24 24"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg></div>
            <div class="tcard-btn" onclick="copyOut()" title="Copy"><svg viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg></div>
          </div>
        </div>
        <div class="tcard-output empty" id="t-output">Translation will appear here…</div>
        <div class="tcard-footer">
          <div class="tfoot-btn accent" onclick="speakOutput()"><svg viewBox="0 0 24 24"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>Speak</div>
          <div class="tfoot-btn" onclick="copyOut()"><svg viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>Copy</div>
          <div class="tfoot-btn" onclick="saveItem()"><svg viewBox="0 0 24 24"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>Save</div>
          <div class="tfoot-btn" onclick="shareOut()"><svg viewBox="0 0 24 24"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>Share</div>
        </div>
      </div>

      <button class="cta-btn" id="cta-btn" onclick="doTranslate()">
