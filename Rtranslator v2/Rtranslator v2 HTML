<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<meta name="description" content="RTranslator – Real-time AI translation with voice, conversation & walkie-talkie modes">
<meta name="theme-color" content="#080b12">
<meta http-equiv="Content-Security-Policy" content="default-src 'self' 'unsafe-inline' 'unsafe-eval' https://fonts.googleapis.com https://fonts.gstatic.com https://api.anthropic.com; img-src 'self' data:; connect-src https://api.anthropic.com">
<title>RTranslator — AI Voice Translation</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ════════════════════════════════════════════
   DESIGN SYSTEM
════════════════════════════════════════════ */
:root {
  --bg0:   #080b12;
  --bg1:   #0d1119;
  --bg2:   #121722;
  --bg3:   #19202e;
  --bg4:   #1f2840;
  --glow:  #00e5b0;
  --glow2: #3d8bff;
  --glowR: #ff4d75;
  --glowY: #f5c518;
  --text:  #eef2ff;
  --text2: #7a88aa;
  --text3: #3d4d6a;
  --border: rgba(255,255,255,0.06);
  --border2:rgba(255,255,255,0.11);
  --border3:rgba(255,255,255,0.18);
  --r-sm: 10px; --r-md: 14px; --r-lg: 20px; --r-xl: 28px;
  --font-display: 'Syne', sans-serif;
  --font-body: 'Inter', sans-serif;
  --shadow: 0 2px 20px rgba(0,0,0,.5);
  --shadow-glow: 0 0 28px rgba(0,229,176,.18);
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;overflow:hidden;background:var(--bg0);color:var(--text);font-family:var(--font-body);font-size:15px}

/* ════════════════════════════════════════════
   SPLASH SCREEN
════════════════════════════════════════════ */
#splash{
  position:fixed;inset:0;background:var(--bg0);z-index:9999;
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0;
  transition:opacity .5s ease,transform .5s ease;
}
#splash.out{opacity:0;transform:scale(1.04);pointer-events:none}
.splash-orb{
  width:100px;height:100px;border-radius:30px;
  background:linear-gradient(135deg,var(--glow),var(--glow2));
  display:flex;align-items:center;justify-content:center;
  box-shadow:var(--shadow-glow);
  animation:orbFloat 3s ease-in-out infinite;
  margin-bottom:24px;
}
@keyframes orbFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
.splash-orb svg{width:52px;height:52px;stroke:#000;fill:none;stroke-width:2.2;stroke-linecap:round;stroke-linejoin:round}
.splash-title{font-family:var(--font-display);font-size:38px;font-weight:800;letter-spacing:-1px;margin-bottom:8px}
.splash-title em{color:var(--glow);font-style:normal}
.splash-sub{font-size:14px;color:var(--text2);margin-bottom:40px;text-align:center;line-height:1.6;max-width:240px}
.splash-bar{width:180px;height:3px;background:var(--bg3);border-radius:99px;overflow:hidden}
.splash-bar-fill{height:100%;background:linear-gradient(90deg,var(--glow),var(--glow2));border-radius:99px;animation:loadBar 1.6s ease forwards}
@keyframes loadBar{from{width:0}to{width:100%}}

/* ════════════════════════════════════════════
   API KEY SHEET
════════════════════════════════════════════ */
#key-sheet{
  position:fixed;inset:0;z-index:500;
  background:rgba(0,0,0,.75);backdrop-filter:blur(6px);
  display:flex;align-items:flex-end;justify-content:center;
  animation:fadeIn .2s ease;
}
#key-sheet.hidden{display:none}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.sheet-box{
  width:100%;max-width:480px;background:var(--bg2);
  border-radius:var(--r-xl) var(--r-xl) 0 0;
  border:0.5px solid var(--border2);
  padding:28px 24px 40px;
  animation:slideUp .3s ease;
}
@keyframes slideUp{from{transform:translateY(60px);opacity:0}to{transform:translateY(0);opacity:1}}
.sheet-handle{width:36px;height:4px;border-radius:99px;background:var(--bg4);margin:0 auto 24px}
.sheet-title{font-family:var(--font-display);font-size:22px;font-weight:700;margin-bottom:8px}
.sheet-desc{font-size:13px;color:var(--text2);line-height:1.6;margin-bottom:22px}
.sheet-input{
  width:100%;background:var(--bg3);border:0.5px solid var(--border2);
  border-radius:var(--r-md);padding:14px 16px;color:var(--text);
  font-family:monospace;font-size:13px;outline:none;margin-bottom:10px;
  transition:border-color .2s;
}
.sheet-input:focus{border-color:var(--glow)}
.sheet-note{font-size:11px;color:var(--text3);margin-bottom:20px;line-height:1.6}
.sheet-note a{color:var(--glow2);text-decoration:none}
.btn-glow{
  width:100%;padding:16px;border-radius:var(--r-lg);border:none;cursor:pointer;
  background:linear-gradient(135deg,var(--glow),var(--glow2));color:#000;
  font-family:var(--font-display);font-size:15px;font-weight:700;
  transition:all .2s;letter-spacing:.2px;
}
.btn-glow:hover{opacity:.9;transform:translateY(-1px);box-shadow:var(--shadow-glow)}
.btn-glow:active{transform:translateY(0)}
.btn-ghost{
  width:100%;padding:13px;border-radius:var(--r-lg);border:0.5px solid var(--border2);
  background:transparent;color:var(--text2);font-family:var(--font-body);font-size:14px;
  cursor:pointer;margin-top:8px;transition:all .2s;
}
.btn-ghost:hover{background:var(--bg3);color:var(--text);border-color:var(--border3)}

/* ════════════════════════════════════════════
   APP SHELL
════════════════════════════════════════════ */
#app{
  display:flex;flex-direction:column;height:100dvh;
  max-width:480px;margin:0 auto;position:relative;
  background:var(--bg0);
}

/* ── Top Bar ── */
#topbar{
  display:flex;align-items:center;justify-content:space-between;
  padding:14px 20px 10px;flex-shrink:0;
}
.brand{display:flex;align-items:center;gap:10px;cursor:default}
.brand-icon{
  width:34px;height:34px;border-radius:10px;
  background:linear-gradient(135deg,var(--glow),var(--glow2));
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 0 14px rgba(0,229,176,.25);
}
.brand-icon svg{width:18px;height:18px;stroke:#000;fill:none;stroke-width:2.2;stroke-linecap:round;stroke-linejoin:round}
.brand-name{font-family:var(--font-display);font-size:17px;font-weight:700;letter-spacing:-.3px}
.brand-name em{color:var(--glow);font-style:normal}
.topbar-actions{display:flex;gap:8px}
.icon-btn{
  width:34px;height:34px;border-radius:10px;
  background:var(--bg2);border:0.5px solid var(--border);
  display:flex;align-items:center;justify-content:center;cursor:pointer;
  transition:all .15s;
}
.icon-btn:hover{background:var(--bg3);border-color:var(--border2)}
.icon-btn svg{width:15px;height:15px;stroke:var(--text2);fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}
.icon-btn.danger svg{stroke:var(--glowR)}

/* ── Mode indicator pill ── */
#mode-pill{
  display:flex;align-items:center;justify-content:center;gap:6px;
  padding:5px 12px;background:var(--bg2);border:0.5px solid var(--border);
  border-radius:99px;margin:0 20px 12px;flex-shrink:0;
}
.mode-dot{width:6px;height:6px;border-radius:50%;background:var(--glow);animation:blink 2s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.mode-label{font-size:10px;font-weight:600;color:var(--text2);letter-spacing:1.5px;font-family:monospace}
.mode-time{font-size:10px;color:var(--text3);font-family:monospace;margin-left:auto}

/* ── Tab Navigation ── */
#tabs{
  display:flex;gap:3px;padding:0 20px 14px;flex-shrink:0;
}
.tab{
  flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;
  padding:9px 6px;border-radius:var(--r-md);cursor:pointer;
  border:0.5px solid transparent;transition:all .2s;
  font-size:10px;font-weight:600;color:var(--text3);letter-spacing:.5px;
  font-family:var(--font-display);text-transform:uppercase;
  user-select:none;
}
.tab svg{width:19px;height:19px;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}
.tab.active{background:var(--bg3);border-color:var(--border2);color:var(--glow)}
.tab:not(.active):hover{color:var(--text2);background:var(--bg1)}

/* ── Main Scroll Area ── */
#main{flex:1;overflow-y:auto;padding:0 20px 20px;scrollbar-width:none;min-height:0}
#main::-webkit-scrollbar{display:none}

/* Screen visibility */
.screen{display:none;flex-direction:column;gap:12px;padding-bottom:4px}
.screen.active{display:flex;animation:screenIn .2s ease}
@keyframes screenIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}

/* ════════════════════════════════════════════
   LANGUAGE SELECTOR
════════════════════════════════════════════ */
.lang-card{
  background:var(--bg2);border:0.5px solid var(--border2);border-radius:var(--r-lg);
  padding:14px 16px;display:flex;align-items:center;gap:10px;
}
.lang-pick{
  flex:1;background:transparent;border:none;color:var(--text);
  font-family:var(--font-body);font-size:14px;font-weight:500;cursor:pointer;
  appearance:none;outline:none;
}
.lang-pick option{background:#1a2035}
.lang-sep{font-size:18px;color:var(--text3);flex-shrink:0}
.swap-btn{
  width:30px;height:30px;border-radius:8px;background:rgba(0,229,176,.08);
  border:0.5px solid rgba(0,229,176,.2);display:flex;align-items:center;
  justify-content:center;cursor:pointer;transition:all .15s;flex-shrink:0;
}
.swap-btn:hover{background:rgba(0,229,176,.16);transform:scale(1.05)}
.swap-btn:active{transform:scale(.95)}
.swap-btn svg{width:14px;height:14px;stroke:var(--glow);fill:none;stroke-width:2.2;stroke-linecap:round;stroke-linejoin:round}

/* ════════════════════════════════════════════
   TEXT TRANSLATION SCREEN
════════════════════════════════════════════ */
.tcard{
  background:var(--bg2);border:0.5px solid var(--border2);border-radius:var(--r-lg);
  overflow:hidden;
}
.tcard-header{
  display:flex;align-items:center;justify-content:space-between;
  padding:11px 14px;border-bottom:0.5px solid var(--border);
}
.tcard-lang-label{font-size:10px;font-weight:700;color:var(--text2);letter-spacing:1.4px;font-family:monospace}
.tcard-actions{display:flex;gap:6px}
.tcard-btn{
  width:28px;height:28px;border-radius:7px;background:var(--bg3);border:0.5px solid var(--border);
  display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .15s;
}
.tcard-btn:hover{background:var(--bg4);border-color:var(--border2)}
.tcard-btn svg{width:13px;height:13px;stroke:var(--text2);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.tcard-btn.active svg{stroke:var(--glowR)}
.tcard-body{position:relative}
textarea.tcard-ta{
  width:100%;min-height:120px;background:transparent;border:none;
  padding:14px 16px 36px;color:var(--text);font-family:var(--font-body);
  font-size:16px;resize:none;outline:none;line-height:1.65;
}
textarea.tcard-ta::placeholder{color:var(--text3)}
.char-ring{
  position:absolute;bottom:10px;right:14px;
  font-size:10px;color:var(--text3);font-family:monospace;
  display:flex;align-items:center;gap:4px;
}
.tcard-output{
  min-height:120px;padding:14px 16px;font-size:16px;line-height:1.65;
  color:var(--text);background:var(--bg1);border-top:0.5px solid var(--border);
  position:relative;transition:all .2s;
}
.tcard-output.empty{color:var(--text3);font-style:italic}
.tcard-output.loading{color:var(--text3)}

/* Streaming cursor */
.cursor-blink::after{content:'▋';animation:cur .6s step-end infinite;color:var(--glow)}
@keyframes cur{0%,100%{opacity:1}50%{opacity:0}}

.tcard-footer{
  display:flex;gap:6px;padding:10px 14px;
  border-top:0.5px solid var(--border);background:var(--bg1);flex-wrap:wrap;
}
.tfoot-btn{
  display:flex;align-items:center;gap:5px;padding:6px 12px;
  border-radius:8px;background:var(--bg3);border:0.5px solid var(--border);
  cursor:pointer;color:var(--text2);font-size:12px;font-weight:500;
  transition:all .15s;font-family:var(--font-body);white-space:nowrap;
}
.tfoot-btn:hover{background:var(--bg4);color:var(--text);border-color:var(--border2)}
.tfoot-btn svg{width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.tfoot-btn.accent{background:rgba(0,229,176,.08);border-color:rgba(0,229,176,.2);color:var(--glow)}
.tfoot-btn.accent:hover{background:rgba(0,229,176,.15)}

/* Translate CTA */
.cta-btn{
  width:100%;padding:17px;border-radius:var(--r-lg);border:none;cursor:pointer;
  background:linear-gradient(135deg,var(--glow),var(--glow2));color:#000;
  font-family:var(--font-display);font-size:15px;font-weight:700;
  display:flex;align-items:center;justify-content:center;gap:9px;
  transition:all .2s;letter-spacing:.1px;
}
.cta-btn:hover{opacity:.9;transform:translateY(-1px);box-shadow:0 4px 20px rgba(0,229,176,.3)}
.cta-btn:active{transform:translateY(0)}
.cta-btn:disabled{opacity:.45;cursor:not-allowed;transform:none;box-shadow:none}
.cta-btn svg{width:18px;height:18px;stroke:#000;fill:none;stroke-width:2.2;stroke-linecap:round;stroke-linejoin:round}

/* Status bar */
.status-line{
  display:flex;align-items:center;justify-content:center;gap:7px;
  min-height:32px;font-size:12px;color:var(--text3);padding:2px 0;
}
.spinner{
  width:14px;height:14px;border:2px solid var(--bg4);border-top-color:var(--glow);
  border-radius:50%;animation:spin .6s linear infinite;flex-shrink:0;
}
@keyframes spin{to{transform:rotate(360deg)}}

/* ════════════════════════════════════════════
   MIC BUTTON & WAVEFORM
════════════════════════════════════════════ */
.mic-wrap{display:flex;align-items:center;gap:12px}
.mic-main{
  width:52px;height:52px;border-radius:50%;border:none;cursor:pointer;flex-shrink:0;
  background:var(--bg3);border:1.5px solid var(--border2);
  display:flex;align-items:center;justify-content:center;
  transition:all .2s;
}
.mic-main:hover{border-color:var(--glow);background:rgba(0,229,176,.08)}
.mic-main.rec{background:rgba(255,77,117,.1);border-color:var(--glowR);animation:micPulse 1.2s ease infinite}
@keyframes micPulse{0%,100%{box-shadow:0 0 0 0 rgba(255,77,117,.35)}60%{box-shadow:0 0 0 14px rgba(255,77,117,0)}}
.mic-main svg{width:22px;height:22px;stroke:var(--text2);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;transition:stroke .2s}
.mic-main.rec svg{stroke:var(--glowR)}

/* Waveform bars */
.waveform{display:flex;align-items:center;gap:3px;height:32px;flex:1}
.wbar{
  width:3px;height:6px;border-radius:99px;background:var(--bg4);
  transition:height .1s ease,background .2s;
}
.waveform.active .wbar{
  background:var(--glow);
  animation:wave 1s ease-in-out infinite;
}
.wbar:nth-child(1){animation-delay:0s;--wh:14px}
.wbar:nth-child(2){animation-delay:.1s;--wh:22px}
.wbar:nth-child(3){animation-delay:.2s;--wh:28px}
.wbar:nth-child(4){animation-delay:.15s;--wh:18px}
.wbar:nth-child(5){animation-delay:.25s;--wh:24px}
.wbar:nth-child(6){animation-delay:.05s;--wh:16px}
.wbar:nth-child(7){animation-delay:.3s;--wh:20px}
@keyframes wave{0%,100%{height:6px}50%{height:var(--wh,18px)}}
.mic-hint-text{font-size:12px;color:var(--text3);flex:1}

/* ════════════════════════════════════════════
   CONVERSATION SCREEN
════════════════════════════════════════════ */
.peer-strip{
  display:flex;align-items:center;gap:12px;
  background:var(--bg2);border:0.5px solid var(--border2);border-radius:var(--r-lg);
  padding:12px 16px;
}
.peer-av{
  width:38px;height:38px;border-radius:50%;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-size:14px;font-weight:700;
}
.peer-av.teal{background:rgba(0,229,176,.1);color:var(--glow)}
.peer-av.blue{background:rgba(61,139,255,.1);color:var(--glow2)}
.peer-info{flex:1}
.peer-name{font-size:14px;font-weight:600}
.peer-sig{font-size:11px;color:var(--text3);display:flex;align-items:center;gap:5px;margin-top:2px}
.peer-dot{width:6px;height:6px;border-radius:50%;background:var(--glow)}
.chat-scroll{
  flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:10px;
  scrollbar-width:none;min-height:180px;
}
.chat-scroll::-webkit-scrollbar{display:none}
.bubble-wrap{display:flex;flex-direction:column;max-width:82%;animation:bubbleIn .2s ease}
@keyframes bubbleIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.bubble-wrap.me{align-self:flex-end;align-items:flex-end}
.bubble-wrap.peer{align-self:flex-start;align-items:flex-start}
.bubble{padding:11px 14px;border-radius:16px;font-size:14px;line-height:1.6}
.bubble-wrap.me .bubble{background:linear-gradient(135deg,var(--glow),#4eaeff);color:#000;border-bottom-right-radius:4px}
.bubble-wrap.peer .bubble{background:var(--bg3);border:0.5px solid var(--border2);border-bottom-left-radius:4px}
.bubble-trans{font-size:11px;color:var(--text3);padding:2px 5px;display:flex;align-items:center;gap:4px;margin-top:2px}
.bubble-trans::before{content:'↳';color:var(--glow)}
.bubble-meta{font-size:10px;color:var(--text3);padding:0 5px;font-family:monospace}
.compose-row{display:flex;gap:8px;align-items:flex-end;padding-top:8px}
.compose-box{
  flex:1;background:var(--bg2);border:0.5px solid var(--border2);border-radius:var(--r-lg);
  padding:12px 14px;transition:border-color .2s;
}
.compose-box:focus-within{border-color:rgba(0,229,176,.35)}
.compose-box textarea{
  width:100%;background:transparent;border:none;color:var(--text);
  font-family:var(--font-body);font-size:14px;resize:none;outline:none;
  max-height:90px;line-height:1.55;
}
.compose-box textarea::placeholder{color:var(--text3)}
.compose-btns{display:flex;flex-direction:column;gap:6px}
.c-send{
  width:42px;height:42px;border-radius:50%;border:none;cursor:pointer;
  background:linear-gradient(135deg,var(--glow),var(--glow2));
  display:flex;align-items:center;justify-content:center;transition:all .2s;
}
.c-send:hover{opacity:.9;transform:scale(1.06)}
.c-send svg{width:17px;height:17px;stroke:#000;fill:none;stroke-width:2.2;stroke-linecap:round;stroke-linejoin:round}
.c-mic{
  width:42px;height:42px;border-radius:50%;border:1.5px solid var(--border2);
  background:var(--bg2);display:flex;align-items:center;justify-content:center;
  cursor:pointer;transition:all .2s;
}
.c-mic:hover{border-color:var(--glow)}
.c-mic svg{width:17px;height:17px;stroke:var(--text2);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.c-mic.rec{border-color:var(--glowR);background:rgba(255,77,117,.1)}
.c-mic.rec svg{stroke:var(--glowR)}

/* ════════════════════════════════════════════
   WALKIE-TALKIE SCREEN
════════════════════════════════════════════ */
.walkie-header{text-align:center;padding:4px 0 12px}
.walkie-header p{font-size:12px;color:var(--text3);line-height:1.6}
.walkie-grid{display:grid;grid-template-columns:1fr auto 1fr;gap:10px;align-items:center;margin-bottom:14px}
.walkie-pad{
  background:var(--bg2);border:0.5px solid var(--border2);border-radius:var(--r-lg);
  padding:20px 12px;text-align:center;cursor:pointer;transition:all .25s;user-select:none;
}
.walkie-pad:hover{border-color:var(--border3);background:var(--bg3)}
.walkie-pad.talking{border-color:var(--glow);background:rgba(0,229,176,.07);box-shadow:var(--shadow-glow)}
.walkie-pad.glowing-red{border-color:var(--glowR);background:rgba(255,77,117,.07);box-shadow:0 0 24px rgba(255,77,117,.18)}
.walkie-pad-icon{
  width:48px;height:48px;border-radius:50%;margin:0 auto 10px;
  background:var(--bg3);border:1.5px solid var(--border2);
  display:flex;align-items:center;justify-content:center;transition:all .25s;
}
.walkie-pad.talking .walkie-pad-icon{border-color:var(--glow);background:rgba(0,229,176,.1)}
.walkie-pad-icon svg{width:22px;height:22px;stroke:var(--text2);fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;transition:stroke .2s}
.walkie-pad.talking .walkie-pad-icon svg{stroke:var(--glow)}
.walkie-pad-name{font-size:13px;font-weight:600;font-family:var(--font-display)}
.walkie-pad-lang{font-size:11px;color:var(--text3);margin-top:3px;font-family:monospace}
.walkie-center{
  width:38px;height:38px;border-radius:50%;background:var(--bg2);border:0.5px solid var(--border2);
  display:flex;align-items:center;justify-content:center;
}
.walkie-center svg{width:16px;height:16px;stroke:var(--text3);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.walkie-status{
  text-align:center;padding:10px;min-height:44px;
  display:flex;align-items:center;justify-content:center;gap:8px;
}

/* ════════════════════════════════════════════
   HISTORY SCREEN
════════════════════════════════════════════ */
.hist-toprow{display:flex;align-items:center;justify-content:space-between;margin-bottom:4px}
.hist-title{font-family:var(--font-display);font-size:17px;font-weight:700}
.hist-clear{
  display:flex;align-items:center;gap:5px;padding:6px 12px;
  border-radius:8px;background:var(--bg2);border:0.5px solid var(--border);
  cursor:pointer;color:var(--text3);font-size:12px;transition:all .15s;
}
.hist-clear:hover{border-color:var(--glowR);color:var(--glowR)}
.hist-clear svg{width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.hist-item{
  display:flex;gap:12px;align-items:flex-start;
  padding:13px 14px;background:var(--bg2);border:0.5px solid var(--border);
  border-radius:var(--r-md);cursor:pointer;transition:all .15s;
}
.hist-item:hover{border-color:var(--border2);background:var(--bg3)}
.hist-flag{
  width:36px;height:36px;border-radius:9px;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;font-size:18px;
}
.hist-flag.a{background:rgba(0,229,176,.08)}
.hist-flag.b{background:rgba(61,139,255,.08)}
.hist-body{flex:1;min-width:0}
.hist-orig{font-size:13px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.hist-translated{font-size:12px;color:var(--text2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:2px}
.hist-langs{font-size:10px;color:var(--text3);margin-top:4px;font-family:monospace}
.hist-time{font-size:10px;color:var(--text3);font-family:monospace;white-space:nowrap;padding-top:2px}
.hist-empty{text-align:center;color:var(--text3);padding:40px 0;font-size:14px}
.hist-empty-icon{font-size:40px;margin-bottom:12px}

/* ════════════════════════════════════════════
   SETTINGS SCREEN
════════════════════════════════════════════ */
.settings-back{
  display:flex;align-items:center;gap:10px;margin-bottom:16px;cursor:pointer;
}
.settings-back svg{width:18px;height:18px;stroke:var(--text2);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.settings-back span{font-size:13px;color:var(--text2)}
.settings-hero{font-family:var(--font-display);font-size:22px;font-weight:700;margin-bottom:20px}
.settings-group{margin-bottom:20px}
.settings-group-label{
  font-size:9px;font-weight:700;color:var(--text3);letter-spacing:1.8px;
  text-transform:uppercase;font-family:monospace;margin-bottom:8px;padding:0 2px;
}
.setting-row{
  display:flex;align-items:center;gap:12px;padding:13px 14px;
  background:var(--bg2);border:0.5px solid var(--border);border-radius:var(--r-md);margin-bottom:5px;
}
.setting-icon{
  width:32px;height:32px;border-radius:9px;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
}
.setting-icon svg{width:15px;height:15px;fill:none;stroke:currentColor;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}
.si-green{background:rgba(0,229,176,.1);color:var(--glow)}
.si-blue{background:rgba(61,139,255,.1);color:var(--glow2)}
.si-yellow{background:rgba(245,197,24,.1);color:var(--glowY)}
.si-red{background:rgba(255,77,117,.1);color:var(--glowR)}
.setting-info{flex:1}
.setting-name{font-size:13px;font-weight:500}
.setting-desc{font-size:11px;color:var(--text3);margin-top:2px}
.setting-value{font-size:12px;color:var(--text2);display:flex;align-items:center;gap:5px}
.setting-value svg{width:13px;height:13px;stroke:var(--text3);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
/* Toggle */
.tgl{position:relative;width:42px;height:23px;flex-shrink:0}
.tgl input{opacity:0;width:0;height:0;position:absolute}
.tgl-track{position:absolute;inset:0;border-radius:99px;background:var(--bg3);border:0.5px solid var(--border2);cursor:pointer;transition:.2s}
.tgl-track::before{content:'';position:absolute;width:17px;height:17px;border-radius:50%;left:3px;top:2px;background:var(--text3);transition:.2s}
.tgl input:checked + .tgl-track{background:rgba(0,229,176,.12);border-color:var(--glow)}
.tgl input:checked + .tgl-track::before{transform:translateX(19px);background:var(--glow)}
/* Privacy badge */
.privacy-badge{
  display:flex;align-items:center;gap:8px;padding:12px 14px;
  background:rgba(0,229,176,.05);border:0.5px solid rgba(0,229,176,.15);
  border-radius:var(--r-md);margin-bottom:20px;
}
.privacy-badge svg{width:16px;height:16px;stroke:var(--glow);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0}
.privacy-badge p{font-size:12px;color:var(--text2);line-height:1.55}

/* ════════════════════════════════════════════
   TOAST
════════════════════════════════════════════ */
#toast{
  position:fixed;bottom:20px;left:50%;transform:translateX(-50%) translateY(10px);
  background:var(--bg3);border:0.5px solid var(--border2);border-radius:var(--r-md);
  padding:11px 20px;font-size:13px;font-weight:500;color:var(--text);
  opacity:0;transition:all .25s;pointer-events:none;white-space:nowrap;z-index:300;
  max-width:calc(100% - 40px);text-align:center;box-shadow:var(--shadow);
}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
#toast.err{border-color:var(--glowR);color:var(--glowR)}
#toast.ok{border-color:var(--glow);color:var(--glow)}

/* ════════════════════════════════════════════
   SECURITY: API key masking indicator
════════════════════════════════════════════ */
.key-masked{
  display:inline-flex;align-items:center;gap:5px;
  font-family:monospace;font-size:11px;color:var(--glow);
}
.key-dot{width:5px;height:5px;border-radius:50%;background:var(--glow);display:inline-block}

/* Responsive */
@media(max-width:360px){.tab{font-size:9px;padding:8px 4px}}
</style>
</head>
<body>

<!-- ════ SPLASH ════ -->
