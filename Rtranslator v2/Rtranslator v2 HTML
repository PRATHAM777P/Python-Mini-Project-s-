          <div class="bubble-trans">Hello! How are you today?</div>
          <div class="bubble-meta">Peer · just now</div>
        </div>
        <div class="bubble-wrap me">
          <div class="bubble">I'm great, this translation is amazing!</div>
          <div class="bubble-trans">¡Estoy genial, esta traducción es increíble!</div>
          <div class="bubble-meta">You · just now</div>
        </div>
      </div>
      <div class="compose-row">
        <div class="compose-box">
          <textarea id="c-input" placeholder="Type your message…" rows="2" onkeydown="convKey(event)"></textarea>
        </div>
        <div class="compose-btns">
          <button class="c-mic" id="c-mic-btn" onclick="convMic()">
            <svg viewBox="0 0 24 24"><path d="M12 2a3 3 0 0 1 3 3v6a3 3 0 0 1-6 0V5a3 3 0 0 1 3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg>
          </button>
          <button class="c-send" onclick="convSend()">
            <svg viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
        </div>
      </div>
    </div>

    <!-- ══ WALKIE-TALKIE SCREEN ══ -->
    <div class="screen" id="screen-walkie">
      <div class="walkie-header">
        <p>Tap a side to speak — the other person hears<br>the translation automatically</p>
